{
  "name": "upwords",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "vite --config frontend/vite.config.ts",
    "dev": "npm run build && wrangler dev -c worker/wrangler.toml",
    "build": "vite build --config frontend/vite.config.ts",
    "deploy": "npm run build && wrangler deploy -c worker/wrangler.toml",
    "test": "vitest",
    "typecheck": "tsc -p worker/tsconfig.json && tsc -p frontend/tsconfig.json"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.98.0"
  }
}
