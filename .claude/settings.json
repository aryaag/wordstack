{
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebSearch",
      "WebFetch",
      "Read(//tmp/**)",
      "Read(//sys/**)",
      "Read(//dev/**)",
      "Skill(*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/check-knowledge-capture.sh"
          }
        ]
      }
    ]
  }
}
